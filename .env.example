# Email notification (scripts/send_email.py)
# Copy to .env and fill in real values:  cp env.example .env
# Load before running:                   set -a; source .env; set +a

# For Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords and use it as SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_TO=you@gmail.com
# SMTP_FROM=you@gmail.com   # optional; defaults to SMTP_USER
